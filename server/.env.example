# MongoDB Atlas (cloud) — Database → Connect → Drivers → copy connection string
# Dạng: mongodb+srv://USER:PASSWORD@cluster....mongodb.net/DATABASE?retryWrites=true&w=majority
# Chỉ MỘT dấu @ trước tên cluster (giữa password và host). Nếu mật khẩu có @ # : / ? ký tự đặc biệt → URL-encode (vd. @ → %40).
# Nhiều tham số query: dùng & (không dùng ? lần hai). Ví dụ: ?appName=Cluster0&retryWrites=true&w=majority
# Network Access: cho phép IP (hoặc 0.0.0.0/0 khi dev).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/harvest_hearth?retryWrites=true&w=majority

# Clerk Dashboard → API Keys → Secret keys (chỉ dùng trên server, không đưa vào app)
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

PORT=8787
