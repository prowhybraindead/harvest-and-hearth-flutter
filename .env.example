# Sao chép file này thành .env và điền vào các giá trị
# Copy this file to .env and fill in the values

# Groq API Key (chính) — https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Gemini API Key (backup) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Supabase ──────────────────────────────────────────────────────────────────
# Tạo project tại https://supabase.com → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
